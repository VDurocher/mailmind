# Récupère depuis : Project Settings > Database > Connection string
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@...

# OpenAI — côté serveur uniquement, JAMAIS de préfixe NEXT_PUBLIC_
OPENAI_API_KEY=sk-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
